# Copy this file to .env.local and fill in the values from your Supabase project.
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-only key (used for admin tasks like creating users). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AI poster engine (Codex Poster Bridge) -------------------------------
# WHERE the 5-agent pipeline runs:
#   inngest = today's path (Inngest functions on Vercel)   [default]
#   server  = our own always-on worker pulls jobs and runs them
POSTER_ENGINE=inngest

# WHICH model backend the agents call:
#   openai = OpenAI SDK via API key (today's behaviour)     [default]
#   codex  = Codex on a ChatGPT subscription (stubbed until Phase 5)
MODEL_ENGINE=openai

# Required when MODEL_ENGINE=openai (and during the Codex stub stage, since the
# stub still uses OpenAI for the cheap text agents). Not needed once real Codex
# is wired and MODEL_ENGINE=codex with a signed-in subscription.
OPENAI_API_KEY=your-openai-key-here

# --- Reel generation: music (Jamendo) -------------------------------------
# Royalty-free music discovery uses the Jamendo API (free; client_id only, no
# secret). Register an app at https://devportal.jamendo.com/ to get the ID.
# Without it, reels fall back to the curated library, then to a silent track.
JAMENDO_CLIENT_ID=your-jamendo-client-id
# Max tracks kept per mood folder in the permanent music library (LFU eviction).
MUSIC_LIBRARY_MAX_PER_MOOD=15

# --- Reel generation: video transcription (local Whisper) -----------------
# Optional. Transcribes uploaded videos so Agent 1 can pick segments by spoken
# content and split long videos into multiple scenes. Install on the worker:
#   pipx install openai-whisper   (ffmpeg must also be present)
# If absent, transcription is silently skipped (keyframes-only).
WHISPER_CMD=whisper
WHISPER_MODEL=base            # base = fast; small/medium = more accurate, slower
# WHISPER_TIMEOUT_MS=240000

# --- Reel generation: composition tuning (all optional, have defaults) -----
# Logo size band (longest edge, px, on the 1080-wide canvas):
REEL_LOGO_MIN_PX=128
REEL_LOGO_MAX_PX=320
# Per-SCENE video length bounds (seconds) and how many scenes one long video may
# supply. A long clip is split into many scenes to fill the requested duration.
REEL_MIN_VIDEO_SCENE_SEC=4
REEL_MAX_VIDEO_SCENE_SEC=8
REEL_MAX_SEGMENTS_PER_VIDEO=24

# Copy this file to .env.local and fill in the values from your Supabase project.
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-only key (used for admin tasks like creating users). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AI poster engine (Codex Poster Bridge) -------------------------------
# WHERE the 5-agent pipeline runs:
#   inngest = today's path (Inngest functions on Vercel)   [default]
#   server  = our own always-on worker pulls jobs and runs them
POSTER_ENGINE=inngest

# WHICH model backend the agents call:
#   openai = OpenAI SDK via API key (today's behaviour)     [default]
#   codex  = Codex on a ChatGPT subscription (stubbed until Phase 5)
MODEL_ENGINE=openai

# Required when MODEL_ENGINE=openai (and during the Codex stub stage, since the
# stub still uses OpenAI for the cheap text agents). Not needed once real Codex
# is wired and MODEL_ENGINE=codex with a signed-in subscription.
OPENAI_API_KEY=your-openai-key-here

# --- Reel generation: music (Jamendo) -------------------------------------
# Royalty-free music discovery uses the Jamendo API (free; client_id only, no
# secret). Register an app at https://devportal.jamendo.com/ to get the ID.
# Without it, reels fall back to the curated library, then to a silent track.
JAMENDO_CLIENT_ID=your-jamendo-client-id
# Max tracks kept per mood folder in the permanent music library (LFU eviction).
MUSIC_LIBRARY_MAX_PER_MOOD=15

# --- Reel generation: video transcription (local Whisper) -----------------
# Optional. Transcribes uploaded videos so Agent 1 can pick segments by spoken
# content and split long videos into multiple scenes. Two backends, auto-selected:
#
# PREFERRED — whisper.cpp (fast, no Python; Metal-accelerated on macOS).
#   brew install whisper-cpp
#   curl -L -o ~/whisper-models/ggml-base.en.bin \
#     https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin
#   # Setting WHISPER_CPP_MODEL switches the backend to whisper.cpp:
# WHISPER_CPP_MODEL=/abs/path/ggml-base.en.bin
# WHISPER_CPP_BIN=whisper-cli
#
# FALLBACK — openai-whisper Python CLI (used when WHISPER_CPP_MODEL is unset).
#   pipx install openai-whisper   (ffmpeg must also be present)
WHISPER_CMD=whisper
WHISPER_MODEL=base            # base = fast; small/medium = more accurate, slower
# WHISPER_TIMEOUT_MS=240000
#
# If neither is installed, transcription is silently skipped (keyframes-only).

# --- Reel generation: composition tuning (all optional, have defaults) -----
# Logo size band (longest edge, px, on the 1080-wide canvas):
REEL_LOGO_MIN_PX=128
REEL_LOGO_MAX_PX=320
# Per-SCENE video length bounds (seconds) and how many scenes one long video may
# supply. A long clip is split into many scenes to fill the requested duration.
REEL_MIN_VIDEO_SCENE_SEC=4
REEL_MAX_VIDEO_SCENE_SEC=8
REEL_MAX_SEGMENTS_PER_VIDEO=24
# Safe-area margins (px) for TEXT/LOGO/GRAPHICS on the 1080x1920 canvas (NOT for
# background media, which stays full-bleed). Platform-aware per Instagram Reels:
# big bottom clears caption/controls, right clears the action buttons.
REEL_SAFE_TOP_PX=100
REEL_SAFE_SIDE_PX=100
REEL_SAFE_RIGHT_PX=120
REEL_SAFE_BOTTOM_PX=280
# Minimum font size (px) for any text — keeps fine print legible on a phone.
REEL_MIN_FONT_PX=28
# Output MP4 encoding (applied BY THE RENDERER directly — no separate re-encode pass).
# CRF is the main quality knob: LOWER = higher quality + bigger file. Default 20 (crisp).
# Use 18 for near-lossless/large, or 28 for the old small (<~25MB) behaviour.
REEL_VIDEO_CRF=20
REEL_VIDEO_PRESET=fast        # x264 preset: slower presets shrink the file at same quality
REEL_AUDIO_BITRATE=192k
# RENDER SPEED (Remotion). gl=angle uses the GPU (Metal on macOS) — the biggest render
# speedup; set REEL_RENDER_GL=swiftshader to fall back to software if a render looks wrong.
# REEL_RENDER_CONCURRENCY = frames rendered in parallel (≈ browser tabs); unset = Remotion
# auto (~half the cores); raise toward core count for a faster single render (more RAM).
REEL_RENDER_GL=angle
# REEL_RENDER_CONCURRENCY=8
# Evaluate→refine loop. Each refine round = another full render (~5 min) + eval, so
# these trade quality for job latency. PASS_SCORE: stop refining once a variation
# scores >= this. MAX_REFINE_ROUNDS: hard cap on refine rounds (0 = no refinement).
REEL_PASS_SCORE=7
REEL_MAX_REFINE_ROUNDS=2

